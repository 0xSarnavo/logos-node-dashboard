# ============================================================================
# Logos Node Dashboard — environment template
# Copy to `.env` (which is gitignored) and fill in values.
# This file contains NO secrets and is safe to commit.
# ============================================================================

# ── Grafana ────────────────────────────────────────────────────────────────
# Admin password for Grafana (http://localhost:3000). Leave empty to allow
# anonymous access (fine for a localhost-only setup).
GRAFANA_ADMIN_PASSWORD=
# Allow anonymous (read-only) viewing of Grafana dashboards.
GRAFANA_ANON_ENABLED=true

# ── TimescaleDB ──────────────────────────────────────────────────────────────
# Internal database password. Only reachable inside the Docker network.
# CHANGE THIS before exposing anything beyond localhost.
DB_PASSWORD=logos_internal_db

# ── Logos node connection ────────────────────────────────────────────────────
# The node's HTTP API. From inside Docker, the host is host.docker.internal.
NODE_API=http://host.docker.internal:8080
# The sidecar that reads the node's RocksDB (internal Docker URL).
SIDECAR_API=http://sidecar:8081

# ── Explorer (optional) ──────────────────────────────────────────────────────
# Comma-separated 64-hex wallet public keys to track in the Wallets/Faucet views.
# Leave unset to use the built-in demo keys.
# WALLET_KEYS=5279d197...1607,3b2e4ffb...061c

# How often (seconds) the indexer polls the node API.
POLL_INTERVAL=3

# ============================================================================
# Logos Node Dashboard — environment template
# Copy to `.env` (which is gitignored) and fill in values.
# This file contains NO secrets and is safe to commit.
# ============================================================================

# ── What to run (compose profiles) ───────────────────────────────────────────
# Controls which optional services start. `docker compose` reads this from .env
# automatically, so plain `docker compose up -d` honors it.
#   (empty)        → LEAN: explorer + db + indexer + sidecar + prometheus +
#                    node-exporter. Best for a laptop/Pi/WSL. Open http://localhost:3333
#   public         → also run Caddy (public HTTPS via your domain). Use on a server.
#   tracing        → also run Loki + Tempo + OpenTelemetry (heavy; rarely needed).
#   public,tracing → everything.
COMPOSE_PROFILES=

# ── Grafana ────────────────────────────────────────────────────────────────
# Admin password for Grafana (http://localhost:3000). Leave empty to allow
# anonymous access (fine for a localhost-only setup).
GRAFANA_ADMIN_PASSWORD=
# Allow anonymous (read-only) viewing of Grafana dashboards.
GRAFANA_ANON_ENABLED=true

# ── TimescaleDB ──────────────────────────────────────────────────────────────
# Internal database password. Only reachable inside the Docker network.
# CHANGE THIS before exposing anything beyond localhost. (docker-compose.yml now
# reads this value via ${DB_PASSWORD}, so editing it here actually takes effect.)
DB_PASSWORD=logos_internal_db

# ── Logos node connection ────────────────────────────────────────────────────
# The node's HTTP API. From inside Docker, the host is host.docker.internal.
NODE_API=http://host.docker.internal:8080
# The sidecar that reads the node's RocksDB (internal Docker URL).
SIDECAR_API=http://sidecar:8081

# ── Explorer (optional) ──────────────────────────────────────────────────────
# Comma-separated 64-hex wallet PUBLIC account keys to track in the Wallets/Faucet views.
# (These are public account identifiers used to receive faucet drips / read balances —
# not private signing keys.) Leave unset to use the built-in demo keys.
# WALLET_KEYS=5279d197...1607,3b2e4ffb...061c

# Set to false to disable the faucet drip/automation endpoints entirely.
# Recommended on any remote/exposed deployment (the faucet has no auth of its own).
FAUCET_ENABLED=true

# How often (seconds) the indexer polls the node API. Raise to 5-10 on small
# machines (Raspberry Pi, 1-2 vCPU VMs) to cut idle CPU.
POLL_INTERVAL=3

# ── Node data location (sidecar + indexer read it) ───────────────────────────
# Absolute or relative path to the logos-node data dir on THIS host (the folder
# that holds state/ and the node's log files). Defaults to a sibling ../logos-node.
#   macOS / Linux / cloud : NODE_DIR=/home/you/logos-node   (or leave default if sibling)
#   Raspberry Pi          : NODE_DIR=/home/pi/logos-node
#   WSL2                  : keep the node + this repo under the Linux FS (~/...),
#                           NOT /mnt/c — bind mounts off /mnt/c are slow.
NODE_DIR=../logos-node

# ── Block Production panel ───────────────────────────────────────────────────
# Your node's leader/funding PUBLIC key(s), comma-separated 64-hex. Found in your
# node's user_config.yaml under leader.wallet.funding_pk. Powers the
# "Block Production" (proposed/final/orphaned) panel. Falls back to WALLET_KEYS.
# NODE_LEADER_KEYS=3b2e4ffb...061c

# ── Host metrics (VM panel) ──────────────────────────────────────────────────
# Where the explorer reads CPU/mem/disk for the "Host Machine (VM)" panel.
# Internal Docker URL — leave as-is unless you run Prometheus elsewhere.
PROM_URL=http://prometheus:9090

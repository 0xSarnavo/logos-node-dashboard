{
  "uid": "logos-blockchain",
  "title": "Logos Explorer — Chain",
  "description": "Block production analytics, block times, finality, and chain history",
  "tags": ["logos", "explorer", "chain"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "CHAIN OVERVIEW",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "BLOCK HEIGHT",
      "description": "Latest confirmed block height.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT ts AS time, block_height AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffffff" }, "decimals": 0 } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "AVG BLOCK TIME",
      "description": "Average seconds between blocks (last 30 min).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT NOW() AS time, COALESCE(ROUND(AVG(block_time_ms)/1000.0, 1), 0) AS value FROM block_events WHERE ts > NOW() - INTERVAL '30 minutes'", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#cccccc" }, "unit": "s", "decimals": 1 } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "BLOCKS (1H)",
      "description": "Total blocks produced in the last hour.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT NOW() AS time, COUNT(*) AS value FROM block_events WHERE ts > NOW() - INTERVAL '1 hour'", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffffff" } } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "LIB LAG",
      "description": "Slots between tip and Last Irreversible Block. Lower = faster finality.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT ts AS time, (slot - lib_slot) AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#cccccc" }, "unit": "slots" } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "INDEXED BLOCKS",
      "description": "Total unique block hashes stored in the database.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT NOW() AS time, COUNT(*) AS value FROM blocks", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#888888" } } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "MODE",
      "description": "Node sync mode.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "TimescaleDB",
      "targets": [{ "rawSql": "SELECT ts AS time, mode AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1", "format": "table", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffffff" } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "BLOCK PRODUCTION",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "Block Time (seconds between blocks)",
      "description": "Each bar shows how long it took for the next block to arrive. Consistent heights = stable production. Tall bars = slow slots.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, ROUND(block_time_ms / 1000.0, 1) AS \"Block Time\" FROM block_events WHERE $__timeFilter(ts) ORDER BY ts",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "custom": { "lineWidth": 0, "fillOpacity": 60, "drawStyle": "bars", "showPoints": "never", "gradientMode": "scheme" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#ffffff" },
              { "value": 30, "color": "#cccccc" },
              { "value": 60, "color": "#888888" },
              { "value": 120, "color": "#444444" }
            ]
          },
          "custom.thresholdsStyle": { "mode": "off" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 11,
      "title": "Blocks Per Minute",
      "description": "Number of blocks produced per minute. Shows chain throughput over time.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, COUNT(*) AS \"Blocks / 5min\" FROM block_events WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 0, "fillOpacity": 40, "drawStyle": "bars", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 12,
      "title": "Block Height Growth",
      "description": "Chain height over time. Smooth upward = healthy. Flat = stalled.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('1 minute', ts) AS time, MAX(block_height) AS \"Height\" FROM consensus_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 2, "fillOpacity": 6, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 300,
      "type": "row",
      "title": "FINALITY",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "Finality Lag Over Time",
      "description": "The slot gap between tip and LIB. A stable low line means the consensus is healthy and blocks finalize quickly.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('1 minute', ts) AS time, AVG(slot - lib_slot)::INT AS \"LIB Lag\" FROM consensus_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true },
          "unit": "slots"
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 21,
      "title": "Slot Progression",
      "description": "Slots advanced per 5-minute window. Measures the consensus clock speed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, MAX(slot) - MIN(slot) AS \"Slots Advanced\" FROM consensus_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#888888" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 400,
      "type": "row",
      "title": "BLOCK EXPLORER",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "title": "Latest Blocks",
      "description": "Most recent blocks indexed from the chain.",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 32 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT height AS \"Block\", LEFT(block_hash, 10) || '...' || RIGHT(block_hash, 6) AS \"Hash\", to_char(ts, 'HH24:MI:SS') AS \"Time\" FROM blocks ORDER BY height DESC LIMIT 30",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "align": "left" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Block" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "displayName": "Block", "desc": true }] }
    },
    {
      "id": 31,
      "title": "Block Events (with block times)",
      "description": "Recent block production events showing the time each block took to produce.",
      "type": "table",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 32 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT height AS \"Block\", LEFT(tip_hash, 10) || '...' || RIGHT(tip_hash, 6) AS \"Tip Hash\", ROUND(block_time_ms / 1000.0, 1) || 's' AS \"Block Time\", to_char(ts, 'HH24:MI:SS') AS \"Time\" FROM block_events ORDER BY ts DESC LIMIT 30",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "align": "left" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Block" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Block Time" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "options": { "showHeader": true, "cellHeight": "sm", "sortBy": [{ "displayName": "Block", "desc": true }] }
    }
  ]
}

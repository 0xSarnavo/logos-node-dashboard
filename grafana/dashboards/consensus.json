{
  "uid": "logos-consensus",
  "title": "Logos Node — Consensus",
  "description": "Cryptarchia consensus engine: block production rates, sync progress, fork tracking, processing latency, and consensus logs.",
  "tags": ["logos", "consensus"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "State",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Block Height",
      "description": "The latest block height reported by the Cryptarchia consensus engine. This value comes from Prometheus metrics and updates in real time.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_block_height",
          "legendFormat": "Block Height",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Current Slot",
      "description": "The consensus slot the node is operating in. Slots tick at a fixed cadence determined by the protocol. Each slot is an opportunity to produce a block.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_current_slot",
          "legendFormat": "Slot",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Sync Progress",
      "description": "Percentage of sync completion. 100% means the node is fully caught up with the network tip. Below 100% the node is still downloading and verifying historical blocks.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_sync_progress_percent",
          "legendFormat": "Sync %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#444444" },
              { "value": 50, "color": "#888888" },
              { "value": 90, "color": "#cccccc" },
              { "value": 99, "color": "#ffffff" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Orphan Cache",
      "description": "Number of blocks in the orphan cache. Orphaned blocks arrived before their parent was known. A large cache may indicate out-of-order block delivery or network delays.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_orphan_cache_size",
          "legendFormat": "Orphan Cache",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#ffffff" },
              { "value": 100, "color": "#888888" },
              { "value": 500, "color": "#444444" }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Production",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Block Height Over Time",
      "description": "Block height as reported by the consensus engine over time. A smooth upward curve is healthy; flat sections indicate the node stopped receiving or producing blocks.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_block_height",
          "legendFormat": "Height",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 6,
      "title": "Blocks Received / Produced / Rejected",
      "description": "Per-second rates of blocks received from the network, produced locally, and rejected by validation. A high rejection rate may indicate malicious peers or protocol mismatches.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(logos_cryptarchia_blocks_received_total[5m])",
          "legendFormat": "Received/s",
          "refId": "A"
        },
        {
          "expr": "rate(logos_cryptarchia_blocks_produced_total[5m])",
          "legendFormat": "Produced/s",
          "refId": "B"
        },
        {
          "expr": "rate(logos_cryptarchia_blocks_rejected_total[5m])",
          "legendFormat": "Rejected/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Produced/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#cccccc" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Rejected/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#444444" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 7,
      "title": "Block Processing Latency",
      "description": "Time to validate and apply a block at the p50, p95, and p99 percentiles. High latency at p99 can cause the node to fall behind during bursts of block production.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(logos_cryptarchia_block_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(logos_cryptarchia_block_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(logos_cryptarchia_block_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#cccccc" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#888888" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Forks",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "title": "Fork Count",
      "description": "Number of active chain forks tracked by the consensus engine. Multiple forks are normal during block propagation; persistent forks may signal a network partition.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_cryptarchia_fork_count",
          "legendFormat": "Active Forks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 9,
      "title": "Reorg Rate",
      "description": "Rate of chain reorganisations per second. A reorg means the node switched to a different fork that had more weight. Frequent reorgs indicate competing block producers.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(logos_cryptarchia_reorgs_total[5m])",
          "legendFormat": "Reorgs/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "Consensus Logs",
      "description": "All log entries mentioning cryptarchia, consensus, block, or slot subsystems. Useful for understanding state transitions and diagnosing consensus-layer issues.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=\"logos-node\"} |~ \"cryptarchia|consensus|block|slot\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
{
  "uid": "logos-overview",
  "title": "Logos Explorer",
  "description": "Blockchain explorer and node monitor for the Logos network",
  "tags": ["logos", "explorer"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 1 },
      "options": {
        "mode": "markdown",
        "content": "# LOGOS BLOCKCHAIN EXPLORER\n*Live node monitoring and chain analytics*"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "CHAIN STATUS",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 3 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "BLOCK HEIGHT",
      "description": "Latest block height on the chain. This is the most recent block the node has accepted.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, block_height AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "decimals": 0
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "CURRENT SLOT",
      "description": "The consensus time slot. Slots advance at a fixed rate — each is an opportunity to produce a block.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, slot AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#cccccc" }, "decimals": 0 }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "FINALITY LAG",
      "description": "Slots between current tip and the Last Irreversible Block. Lower = faster finality. >200 may indicate consensus problems.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, (slot - lib_slot) AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "unit": "slots",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#ffffff" },
              { "value": 100, "color": "#888888" },
              { "value": 300, "color": "#444444" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "AVG BLOCK TIME",
      "description": "Average time between new blocks over the last 10 minutes.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT NOW() AS time, COALESCE(ROUND(AVG(block_time_ms) / 1000.0, 1), 0) AS value FROM block_events WHERE ts > NOW() - INTERVAL '10 minutes'",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffffff" }, "unit": "s", "decimals": 1 }
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "PEERS",
      "description": "Number of peers connected to this node on the P2P network.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, n_peers AS value FROM network_snapshots ORDER BY ts DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#444444" },
              { "value": 5, "color": "#cccccc" },
              { "value": 10, "color": "#ffffff" }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "STATUS",
      "description": "Node sync mode — Online means fully synced with the network.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 4 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, mode AS value FROM consensus_snapshots ORDER BY ts DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#ffffff" } }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 102,
      "type": "row",
      "title": "CHAIN ACTIVITY",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "Block Height",
      "description": "Chain height over time. A smooth upward line means healthy block production. Flat sections indicate stalls.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('1 minute', ts) AS time, MAX(block_height) AS \"Block Height\" FROM consensus_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 2, "fillOpacity": 6, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true }
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 11,
      "title": "Peers & Connections",
      "description": "Network connectivity over time. Peers = discovered nodes, Connections = active links.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": "TimescaleDB",
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 minute', ts) AS time, AVG(n_peers)::INT AS \"Peers\", AVG(n_connections)::INT AS \"Connections\" FROM network_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 2, "fillOpacity": 6, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Connections" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#666666" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 12,
      "title": "Block Time",
      "description": "Time between consecutive blocks in seconds. Consistent times mean healthy block production.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT ts AS time, ROUND(block_time_ms / 1000.0, 1) AS \"Block Time (s)\" FROM block_events WHERE $__timeFilter(ts) ORDER BY ts",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "custom": { "lineWidth": 1, "fillOpacity": 12, "drawStyle": "bars", "showPoints": "never" },
          "unit": "s"
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 13,
      "title": "Finality Lag (Tip - LIB)",
      "description": "Gap between current slot and Last Irreversible Block. A growing gap means finality is slowing down.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT time_bucket('1 minute', ts) AS time, AVG(slot - lib_slot)::INT AS \"Finality Lag\" FROM consensus_snapshots WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#888888" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth", "spanNulls": true },
          "unit": "slots"
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 103,
      "type": "row",
      "title": "LATEST BLOCKS",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "",
      "description": "Most recent blocks indexed from the chain. Shows block height, hash (truncated), and when it was indexed.",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "datasource": "TimescaleDB",
      "targets": [{
        "rawSql": "SELECT height AS \"Block\", LEFT(block_hash, 12) || '...' || RIGHT(block_hash, 8) AS \"Hash\", to_char(ts, 'YYYY-MM-DD HH24:MI:SS') AS \"Time\" FROM blocks ORDER BY height DESC LIMIT 25",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "align": "left", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Block" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Hash" }, "properties": [{ "id": "custom.width", "value": 280 }] }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Block", "desc": true }],
        "cellHeight": "sm"
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "NODE RESOURCES",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "title": "CPU",
      "description": "Host CPU usage percentage.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 38 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0, "max": 100, "unit": "percent", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "#444444" },
            { "value": 60, "color": "#888888" },
            { "value": 85, "color": "#cccccc" },
            { "value": 95, "color": "#ffffff" }
          ]}
        }
      }
    },
    {
      "id": 31,
      "title": "RAM",
      "description": "Host memory usage percentage.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 38 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "RAM",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0, "max": 100, "unit": "percent", "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "#444444" },
            { "value": 60, "color": "#888888" },
            { "value": 85, "color": "#cccccc" },
            { "value": 95, "color": "#ffffff" }
          ]}
        }
      }
    },
    {
      "id": 32,
      "title": "CPU Over Time",
      "description": "CPU usage trend over the selected time range.",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 38 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth" },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 33,
      "title": "Memory Over Time",
      "description": "Memory usage trend over the selected time range.",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 38 },
      "datasource": "Prometheus",
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "RAM %",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "drawStyle": "line", "showPoints": "never", "lineInterpolation": "smooth" },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 105,
      "type": "row",
      "title": "RECENT ERRORS",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": true,
      "panels": [
        {
          "id": 40,
          "title": "Error Log Stream",
          "description": "Recent ERROR-level log entries from the node. Expand this section to investigate issues.",
          "type": "logs",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
          "datasource": "Loki",
          "targets": [{ "expr": "{service=\"logos-node\"} |= \"ERROR\"", "refId": "A" }],
          "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
        }
      ]
    }
  ]
}

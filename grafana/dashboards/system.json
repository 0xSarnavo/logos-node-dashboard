{
  "uid": "logos-system",
  "title": "Logos Node — System Resources",
  "description": "Operating-system-level resource monitoring: CPU, memory, disk, network I/O, and file descriptors. Data from node-exporter via Prometheus.",
  "tags": ["logos", "system"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "CPU Usage",
      "description": "Current CPU utilisation as a percentage across all cores. Sustained values above 90% may cause the node to fall behind on block processing.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#444444" },
              { "value": 50, "color": "#888888" },
              { "value": 80, "color": "#cccccc" },
              { "value": 95, "color": "#ffffff" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "description": "Percentage of total system RAM in use. The node uses memory for block caches, peer state, and the consensus engine. High usage risks OOM kills.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#444444" },
              { "value": 50, "color": "#888888" },
              { "value": 80, "color": "#cccccc" },
              { "value": 95, "color": "#ffffff" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Disk Usage",
      "description": "Percentage of the root filesystem in use. The blockchain database grows continuously; running out of disk will halt the node and potentially corrupt data.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "min": 0,
          "max": 100,
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#444444" },
              { "value": 60, "color": "#888888" },
              { "value": 80, "color": "#cccccc" },
              { "value": 95, "color": "#ffffff" }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "CPU Usage Over Time",
      "description": "CPU utilisation percentage over the selected time range. Look for sustained plateaus that indicate the node is compute-bound.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 5,
      "title": "Load Averages",
      "description": "System load averages over 1, 5, and 15 minute windows. Values above the CPU core count indicate the system is overloaded. The 15m average smooths out short bursts.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5m" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#cccccc" } }]
          },
          {
            "matcher": { "id": "byName", "options": "15m" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#888888" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "Memory: Used vs Total",
      "description": "Used memory compared to the total available. The dashed line shows total RAM; the solid area shows consumption. If the used line approaches total, the OOM killer may intervene.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#444444" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "Disk & Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "title": "Disk I/O",
      "description": "Disk read and write throughput in bytes per second. High write rates are expected during sync; sustained high reads may indicate cache misses in the database.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "Bps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Write" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#888888" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 8,
      "title": "Network Traffic (RX / TX)",
      "description": "Host-level network receive and transmit rates across all non-loopback interfaces. Correlate with P2P peer counts to understand bandwidth per peer.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "RX {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "TX {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 500,
      "type": "row",
      "title": "File Descriptors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Open FDs vs Maximum",
      "description": "Number of open file descriptors compared to the system limit. Each peer connection, database file, and log file consumes an FD. Exhausting the limit will prevent new connections.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "node_filefd_allocated",
          "legendFormat": "Open FDs",
          "refId": "A"
        },
        {
          "expr": "node_filefd_maximum",
          "legendFormat": "Max FDs",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max FDs" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#444444" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    }
  ]
}
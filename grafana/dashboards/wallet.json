{
  "uid": "logos-wallet",
  "title": "Logos Node — Wallet",
  "description": "Wallet balance, transaction activity, and faucet-related logs for the Logos node.",
  "tags": ["logos", "wallet"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "style": "dark",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Balance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Current Balance",
      "description": "The wallet's current token balance as reported by the node. This is the spendable balance after all confirmed transactions.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_wallet_balance",
          "legendFormat": "Balance",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Pending Transactions",
      "description": "Number of transactions submitted but not yet included in a finalised block. A growing count may indicate network congestion or the node being out of sync.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_wallet_pending_tx_count",
          "legendFormat": "Pending TX",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#ffffff" },
              { "value": 5, "color": "#888888" },
              { "value": 20, "color": "#444444" }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "Total Transactions Sent",
      "description": "Cumulative count of transactions sent by this wallet since the node started. This counter resets on restart.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_wallet_transactions_sent_total",
          "legendFormat": "Total TX Sent",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#cccccc" }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Transaction Rate",
      "description": "Per-second rate of transactions sent and received (5-minute moving average). Sent rate shows outgoing activity; received rate shows incoming transfers or rewards.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(logos_wallet_transactions_sent_total[5m])",
          "legendFormat": "TX Sent/s",
          "refId": "A"
        },
        {
          "expr": "rate(logos_wallet_transactions_received_total[5m])",
          "legendFormat": "TX Received/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TX Received/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#888888" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 5,
      "title": "Balance Over Time",
      "description": "Wallet balance plotted over time. Upward trends indicate incoming funds or rewards; downward trends indicate spending. Sudden drops may warrant investigation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "logos_wallet_balance",
          "legendFormat": "Balance",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffffff" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 6,
      "title": "Wallet & Faucet Logs",
      "description": "Log entries related to wallet operations, faucet requests, transactions, and token transfers. Useful for tracing individual transaction lifecycle events.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=\"logos-node\"} |~ \"faucet|wallet|transaction|transfer\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}